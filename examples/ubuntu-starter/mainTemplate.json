{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "extensionResourceName": { "type": "string" },
    "clusterResourceId": { "type": "string" }
  },
  "variables": {
    "plan-name": "ubuntu-starter",
    "plan-publisher": "dcassociatesgroup",
    "plan-offerID": "ubuntu-starter",
    "releaseTrain": "stable",
    "clusterExtensionTypeName": "DCAssociatesGroup.UbuntuStarter"
  },
  "resources": [
    {
      "type": "Microsoft.KubernetesConfiguration/extensions",
      "apiVersion": "2024-11-01",
      "name": "[parameters('extensionResourceName')]",
      "scope": "[parameters('clusterResourceId')]",
      "kind": "ClusterExtension",
      "plan": {
        "name": "[variables('plan-name')]",
        "publisher": "[variables('plan-publisher')]",
        "product": "[variables('plan-offerID')]"
      },
      "properties": {
        "extensionType": "[variables('clusterExtensionTypeName')]",
        "autoUpgradeMinorVersion": true,
        "releaseTrain": "[variables('releaseTrain')]"
      }
    }
  ]
}
